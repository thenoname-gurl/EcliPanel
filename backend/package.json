{
  "name": "eclipse-panel-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun src/index.ts",
    "promote": "bun scripts/promote.ts",
    "seed": "bun scripts/seed.ts",
    "fill-sender-rdns": "bun scripts/fill-sender-rdns.ts",
    "notify-missing-profile": "bun scripts/notify-missing-profile.ts",
    "gen:jwt-secret": "bun scripts/generate-jwt-secret.ts",
    "gen:default-role": "bun scripts/create-default-role.ts",
    "build": "bun install && bun tsc || true",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bun tsc --noEmit",
    "lint": "eslint src/ tests/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ tests/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\""
  },
  "engines": {
    "bun": ">=1.0"
  },
  "dependencies": {
    "@canvas/image": "latest",
    "@elysia/cors": "latest",
    "@elysia/jwt": "latest",
    "@elysia/openapi": "latest",
    "@noble/post-quantum": "latest",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@simplewebauthn/server": "latest",
    "@tensorflow/tfjs-node": "latest",
    "@types/bun": "^1.3.14",
    "@vladmandic/face-api": "latest",
    "adm-zip": "latest",
    "base64url": "latest",
    "brace-expansion": "latest",
    "dompurify": "latest",
    "elysia": "latest",
    "elysia-helmet": "latest",
    "file-type": "latest",
    "html-to-text": "latest",
    "imap": "latest",
    "jsonwebtoken": "latest",
    "lodash": "latest",
    "mailparser": "latest",
    "mariadb": "latest",
    "mlkem": "latest",
    "mysql": "latest",
    "mysql2": "^3.22.3",
    "nodemailer": "latest",
    "pdfkit": "latest",
    "pg": "latest",
    "pqclean": "latest",
    "react": "^19.2.6",
    "reflect-metadata": "latest",
    "sharp": "latest",
    "speakeasy": "latest",
    "srvx": "latest",
    "ssh2": "latest",
    "tar": "latest",
    "typeorm": "latest",
    "ws": "latest"
  },
  "dependenciesMeta": {
    "speakeasy": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/base64url": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/node": "latest",
    "@types/nodemailer": "latest",
    "@types/ssh2": "latest",
    "@types/ws": "latest",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "prettier": "latest",
    "typescript": "latest"
  },
  "overrides": {
    "tar": "^7.5.13",
    "follow-redirects": "1.16.0"
  }
}
